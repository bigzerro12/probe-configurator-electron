{
  "appId": "com.probeconfigurator.app",
  "productName": "ProbeConfigurator",
  "directories": {
    "output": "dist",
    "buildResources": "resources"
  },
  "files": [
    "out/**/*",
    "!out/**/*.map"
  ],
  "win": {
    "target": [
      "nsis",
      "portable"
    ],
    "icon": "resources/icons/win/icon.ico",
    "sign": false,
    "signingHashAlgorithms": null,
    "certificateFile": null,
    "certificatePassword": null
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      },
      {
        "target": "zip",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    ],
    "icon": "resources/icons/mac/icon.icns",
    "category": "public.app-category.developer-tools"
  },
  "dmg": {
    "title": "${productName} ${version}",
    "background": null,
    "contents": [
      {
        "x": 130,
        "y": 220,
        "type": "file"
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ],
    "window": {
      "width": 540,
      "height": 400
    }
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "icon": "resources/icons/png",
    "category": "Development"
  },
  "publish": null
}